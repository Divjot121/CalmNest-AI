rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Device Preferences — keyed by device UUID, writable by any authenticated user
    match /devicePreferences/{deviceId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
      match /queries/{queryId} {
        allow read, write: if request.auth != null;
      }
      match /responses/{responseId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /moodLogs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /journalEntries/{entryId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /habits/{habitId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /habitCompletions/{completionId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /assessments/{assessmentId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if false; // Admin write via server / backend only
    }

    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if false; // Admin only via backend
    }
  }
}
